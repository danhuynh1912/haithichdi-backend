DJANGO_DEBUG=0

# Preferred for AWS production: store secrets in SSM Parameter Store SecureString.
DJANGO_SECRET_KEY_SSM_PARAMETER=/haithichdi/prod/backend/django_secret_key

POSTGRES_DB=tours_db
POSTGRES_USER=tours_user
POSTGRES_HOST=replace-me
POSTGRES_PORT=5432
POSTGRES_PASSWORD_SSM_PARAMETER=/haithichdi/prod/backend/postgres_password

USE_S3=1
AWS_STORAGE_BUCKET_NAME=haithichdi-prod-media
AWS_S3_REGION_NAME=ap-southeast-1
AWS_S3_CUSTOM_DOMAIN=replace-me.cloudfront.net

# Leave these unset in AWS when Lambda or ECS already uses IAM roles.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Plaintext fallback for local development only.
# DJANGO_SECRET_KEY=replace-me
# POSTGRES_PASSWORD=replace-me

# MinIO / local-only settings. Do not set these in AWS production.
# AWS_S3_ENDPOINT_URL=
# AWS_S3_PUBLIC_ENDPOINT_URL=
# AWS_S3_PUBLIC_BASE_URL=
# AWS_S3_ADDRESSING_STYLE=path
